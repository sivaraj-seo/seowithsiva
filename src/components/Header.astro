---
---
<div class="nav">
  <div class="wrap">
    <a href="/" class="brand">
      <img src="/images/logo.webp" alt="SEO With Siva" class="logo-img" />
      C. Sivaraj
    </a>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/articles/">Articles</a>
      <a href="/contact/">Contact Me</a>
    </div>
    <!-- Hamburger — mobile only -->
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <!-- Mobile dropdown -->
  <div class="nav-mobile">
    <a href="/">Home</a>
    <a href="/articles/">Articles</a>
    <a href="/contact/">Contact Me</a>
  </div>
</div>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(33,29,51,.06);
  }
  .wrap {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 20px;
    color: #211d33;
    text-decoration: none;
  }
  .logo-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
    border-radius: 6px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 30px;
  }
  .nav-links a:not(.wa-pill) {
    color: #211d33;
    font-weight: 500;
    font-size: 15px;
    opacity: .82;
    text-decoration: none;
    transition: opacity .15s;
  }
  .nav-links a:not(.wa-pill):hover { opacity: 1; }
  /* Hamburger button */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 4px;
    width: 36px;
    height: 36px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #211d33;
    border-radius: 2px;
    transition: transform .22s, opacity .22s;
  }
  .nav-toggle.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-toggle.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile dropdown */
  .nav-mobile {
    display: none;
    flex-direction: column;
    background: #fff;
    border-top: 1px solid rgba(33,29,51,.06);
    padding: 8px 16px 16px;
    box-shadow: 0 12px 32px -8px rgba(33,29,51,.12);
  }
  .nav-mobile.is-open { display: flex; }
  .nav-mobile a:not(.nav-mobile-wa) {
    padding: 13px 8px;
    font-size: 16px;
    font-weight: 600;
    color: #211d33;
    text-decoration: none;
    border-bottom: 1px solid rgba(33,29,51,.06);
    transition: color .12s;
  }
  .nav-mobile a:not(.nav-mobile-wa):hover { color: #7c5cd6; }
  @media (max-width: 900px) {
    .nav-links { gap: 16px; }
    .nav-links a:not(.wa-pill) { font-size: 13px; }
  }
  @media (max-width: 680px) {
    .nav-links { display: none; }
    .nav-toggle { display: flex; }
    .wrap { padding: 0 16px; }
  }
</style>

<script>
  const btn = document.querySelector('.nav-toggle');
  const menu = document.querySelector('.nav-mobile');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    btn.classList.toggle('is-open', open);
    btn.setAttribute('aria-expanded', String(!!open));
  });
  menu?.querySelectorAll('a').forEach(a =>
    a.addEventListener('click', () => {
      menu.classList.remove('is-open');
      btn?.classList.remove('is-open');
      btn?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
