---
const navLinks = [
  { href: '#services', label: 'Services' },
  { href: '#results', label: 'Results' },
  { href: '#about', label: 'About' },
  { href: '#articles', label: 'Articles' },
  { href: '#credentials', label: 'Credentials' },
];
---

<header>
  <div class="inner">
    <a href="/" class="brand">
      <span class="logo">CS</span>
      <span class="name">C. Sivaraj</span>
    </a>
    <nav aria-label="Main navigation">
      <ul>
        {navLinks.map(link => (
          <li><a href={link.href} class="nav-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>
    <a
      href="https://wa.link/l9kdx1"
      target="_blank"
      rel="noopener noreferrer"
      class="btn-wa"
      aria-label="Contact on WhatsApp"
    >WhatsApp</a>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #ede9f8;
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 2.5rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: #7c5cd6;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: -0.5px;
  }

  .name {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f0f0f;
  }

  nav {
    flex: 1;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 0.25rem;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: block;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    color: #555;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: #7c5cd6;
    background: #f5f0ff;
  }

  .btn-wa {
    flex-shrink: 0;
    padding: 0.5rem 1.1rem;
    background: #7c5cd6;
    color: #fff;
    border-radius: 7px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, transform 0.15s;
  }

  .btn-wa:hover {
    background: #5a4ab8;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .inner {
      padding: 0 1rem;
      gap: 1rem;
    }

    nav ul {
      gap: 0;
    }

    .nav-link {
      padding: 0.375rem 0.5rem;
      font-size: 0.8rem;
    }

    .name {
      display: none;
    }
  }

  @media (max-width: 560px) {
    nav {
      display: none;
    }
  }
</style>
