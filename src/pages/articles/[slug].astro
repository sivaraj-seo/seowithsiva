<script>
  // Assign IDs to all headings for anchor links
  document.querySelectorAll<HTMLHeadingElement>('.prose h2, .prose h3')
    .forEach((h, i) => { h.id = `h-${i}`; });

  // Build TOC from H2s only
  const h2s = document.querySelectorAll<HTMLHeadingElement>('.prose h2');
  const tocList = document.getElementById('toc-list');
  const tocLinks: HTMLAnchorElement[] = [];

  if (tocList && h2s.length) {
    h2s.forEach(h => {
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${h.id}`;
      a.textContent = h.textContent || '';
      li.appendChild(a);
      tocList.appendChild(li);
      tocLinks.push(a);
    });

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(a =>
            a.classList.toggle('active', a.getAttribute('href') === `#${entry.target.id}`)
          );
        }
      });
    }, { rootMargin: '-80px 0px -65% 0px', threshold: 0 });

    h2s.forEach(h => observer.observe(h));
  }

  // Inline CTA banner — compact strip injected before the 3rd H2
  const allH2s = Array.from(document.querySelectorAll<HTMLElement>('.prose h2'));
  const ctaTarget = allH2s[2] ?? allH2s[allH2s.length - 1];
  if (ctaTarget) {
    const cta = document.createElement('div');
    cta.className = 'mid-cta';
    cta.innerHTML = `
      <div class="mid-cta-text">
        <div class="mid-cta-label">Free Consultation</div>
        <div class="mid-cta-heading">Is your brand invisible in AI search?</div>
        <div class="mid-cta-body">I'll audit your AI citation footprint and show you exactly where you're missing from ChatGPT, Gemini, and Perplexity — free for the first call.</div>
      </div>
      <a href="/contact/" class="mid-cta-btn">Book a free strategy call →</a>
    `;
    ctaTarget.parentNode!.insertBefore(cta, ctaTarget);
  }
</script>

