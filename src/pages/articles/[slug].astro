---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const allArticles = await getCollection('articles');
const related = allArticles
  .filter(a => a.slug !== article.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const dateOpts: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'long', year: 'numeric' };
const formattedDate = new Date(article.data.date).toLocaleDateString('en-IN', dateOpts);
const formattedLastModified = article.data.lastModified
  ? new Date(article.data.lastModified).toLocaleDateString('en-IN', dateOpts)
  : null;
---

<BaseLayout
  title={article.data.title}
  description={article.data.excerpt}
  author="C. Sivaraj"
  keywords={`SEO, GEO, AEO, ${article.data.category}, C. Sivaraj`}
>

<style>
  *{ box-sizing:border-box; }
  a{ color:inherit; text-decoration:none; }

  .tag{
    display:inline-flex; align-items:center; gap:7px;
    font-size:12px; font-weight:700; letter-spacing:.12em;
    text-transform:uppercase; color:var(--accent);
  }
  .tag::before{ content:''; width:7px; height:7px; border-radius:50%; background:var(--accent); }

  /* ── HERO ── */
  .art-hero{ background:#fff; padding:36px 0 0; border-bottom:1px solid #f0ebf8; }
  .art-hero-inner{
    max-width:1040px; margin:0 auto; padding:0 32px 32px;
  }
  .breadcrumb{
    display:flex; align-items:center; gap:8px;
    font-size:13px; color:var(--muted); margin-bottom:18px;
  }
  .breadcrumb a{ transition:color .12s; }
  .breadcrumb a:hover{ color:var(--accent); }
  .breadcrumb-sep{ opacity:.35; }
  .art-hero h1{
    font-weight:800; font-size:clamp(26px,3.6vw,42px);
    color:var(--ink); margin:12px 0 0; line-height:1.1; letter-spacing:-.025em;
    max-width:22ch;
  }
  .art-meta{
    display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    font-size:14px; color:var(--muted); margin-top:14px;
  }
  .art-meta-dot{ width:3px; height:3px; border-radius:50%; background:#c0bac8; flex-shrink:0; }
  .art-meta-author{ color:var(--accent); font-weight:600; }
  .art-meta-dateline{ display:inline-flex; align-items:baseline; gap:5px; }
  .art-meta-datelabel{ font-size:11px; font-weight:700; letter-spacing:.07em; text-transform:uppercase; color:#b0a9c8; }

  /* Hero image — below meta, above article body */
  .art-hero-img{
    width:100%; max-height:260px;
    object-fit:cover; border-radius:14px;
    margin-top:24px; display:block;
  }

  /* ── MAIN LAYOUT ── */
  .art-layout{
    display:grid;
    grid-template-columns:1fr 228px;
    gap:56px;
    align-items:start;
    max-width:1040px;
    margin:0 auto;
    padding:40px 32px 88px;
  }

  /* ── KEY TAKEAWAYS ── NP-inspired first-section box */
  .key-takeaways{
    background:#efeafc;
    border-left:4px solid var(--accent);
    border-radius:12px;
    padding:22px 26px 20px;
    margin-bottom:44px;
  }
  .kt-label{
    font-size:16px; font-weight:700; letter-spacing:.02em;
    text-transform:uppercase; color:var(--accent); margin-bottom:14px;
  }
  .key-takeaways ul{
    list-style:none; padding:0; margin:0;
  }
  .key-takeaways li{
    font-size:14px; line-height:1.6; color:#2a2545;
    font-weight:500; padding:7px 0 7px 24px; position:relative;
    margin-bottom:6px;
  }
  .key-takeaways li::before{
    content:''; position:absolute; left:2px; top:14px;
    width:8px; height:8px; border-radius:2px;
    background:var(--accent);
  }

  /* ── PROSE ── */
  .prose{ min-width:0; }

  /* ── ARTICLE FOOTER ── */
  .art-share{
    display:flex; align-items:center; gap:10px; flex-wrap:wrap;
    padding:22px 0; border-top:1px solid #ece7f6; margin-top:44px;
  }
  .art-share-label{ font-size:13px; font-weight:600; color:var(--muted); }
  .share-btn{
    display:inline-flex; align-items:center; gap:6px;
    padding:8px 16px; border-radius:999px;
    font-size:13px; font-weight:600;
    background:#f0ebfa; color:var(--accent);
    transition:background .15s, color .15s;
  }
  .share-btn:hover{ background:var(--accent); color:#fff; }
  .share-sep{ color:#d5cfe8; font-size:16px; line-height:1; margin:0 2px; }
  .share-btn--chatgpt{ background:#e6f8f3; color:#0a9070; }
  .share-btn--chatgpt:hover{ background:#0a9070; color:#fff; }
  .share-btn--claude{ background:#fdf0ec; color:#c96838; }
  .share-btn--claude:hover{ background:#c96838; color:#fff; }
  .share-btn--gemini{ background:#e8f0fe; color:#1558c0; }
  .share-btn--gemini:hover{ background:#1558c0; color:#fff; }

  .author-label{
    font-size:11px; font-weight:700; letter-spacing:.1em;
    text-transform:uppercase; color:var(--muted); margin-bottom:10px;
  }
  .art-author{
    display:flex; gap:16px; align-items:flex-start;
    background:#f7f3ff; border-radius:16px;
    padding:22px 24px; margin-top:10px;
    border:1px solid #ece7f6;
  }
  .author-img{
    width:56px; height:56px; border-radius:14px;
    object-fit:cover; object-position:center top; flex-shrink:0;
  }
  .author-name{ font-weight:700; font-size:15px; color:var(--ink); }
  .author-role{ font-size:12px; color:var(--muted); margin-top:2px; }
  .author-bio{ font-size:14px; line-height:1.6; color:#4a4560; margin-top:8px; }
  .author-socials{ display:flex; gap:8px; margin-top:14px; flex-wrap:wrap; }
  .author-social-btn{
    display:inline-flex; align-items:center; gap:6px;
    font-size:12px; font-weight:600;
    padding:6px 12px; border-radius:999px;
    border:1px solid #ddd6f5; color:var(--accent);
    transition:background .13s, color .13s, border-color .13s;
  }
  .author-social-btn:hover{ background:var(--accent); color:#fff; border-color:var(--accent); }
  .author-social-btn svg{ flex-shrink:0; }

  /* ── SIDEBAR ── */
  .sidebar{ position:sticky; top:90px; display:flex; flex-direction:column; gap:16px; }

  .toc-card{
    background:#faf7ff; border-radius:14px;
    border:1px solid #ece7f6; padding:20px 22px;
  }
  .toc-title{
    font-size:15px; font-weight:800; color:var(--ink);
    padding-bottom:12px;
    border-bottom:2px solid var(--accent);
    margin-bottom:16px; letter-spacing:0;
  }
  .toc-list{ list-style:none; padding:0; margin:0; }
  /* :global() needed — li/a are created dynamically by JS and don't carry Astro's scope hash */
  .toc-list :global(li){ margin-bottom:0; }
  .toc-list :global(a){
    font-size:13px; color:#5a5470;
    display:flex; align-items:flex-start; gap:10px;
    padding:7px 4px; line-height:1.45;
    transition:color .12s;
  }
  .toc-list :global(a::before){
    content:''; flex-shrink:0;
    width:8px; height:8px; border-radius:2px;
    background:var(--accent); margin-top:4px;
  }
  .toc-list :global(a:hover){ color:var(--accent); }
  .toc-list :global(a.active){ color:var(--accent); font-weight:700; }

  /* Sidebar consulting CTA — NP-inspired sidebar widget */
  .sidebar-cta{
    background:linear-gradient(160deg,#7c5cd6 0%,#5b3db5 100%);
    border-radius:14px; padding:22px 20px;
  }
  .sidebar-cta-label{
    font-size:10px; font-weight:700; letter-spacing:.12em;
    text-transform:uppercase; color:#c4b5f5; margin-bottom:8px;
  }
  .sidebar-cta-heading{
    font-size:15px; font-weight:800; color:#fff;
    line-height:1.3; margin-bottom:8px;
  }
  .sidebar-cta-text{
    font-size:13px; color:#d4caee; line-height:1.55; margin-bottom:16px;
  }
  .sidebar-cta-btn{
    display:block; text-align:center;
    background:#fff; color:var(--accent);
    font-size:13px; font-weight:700;
    padding:10px 16px; border-radius:999px;
    transition:background .15s;
  }
  .sidebar-cta-btn:hover{ background:#f0ebfa; }

  /* ── RELATED ── */
  .related{
    background:linear-gradient(180deg,#f6ecf6 0%,#fdeee5 100%);
    padding:56px 0 72px;
  }
  .related-wrap{ max-width:1040px; margin:0 auto; padding:0 32px; }
  .related h2{
    font-weight:800; font-size:clamp(22px,3vw,32px);
    margin-top:14px; color:var(--ink);
  }
  .related-grid{
    display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
    gap:20px; margin-top:28px;
  }
  .rel-card{
    display:flex; flex-direction:column;
    background:#fff; border-radius:16px; overflow:hidden;
    box-shadow:0 8px 30px -16px rgba(33,29,51,.3);
    transition:transform .2s, box-shadow .2s;
  }
  .rel-card:hover{ transform:translateY(-3px); box-shadow:0 20px 44px -16px rgba(33,29,51,.4); }
  .rel-thumb{ width:100%; height:160px; object-fit:cover; display:block; flex-shrink:0; }
  .rel-body{ padding:16px 18px 18px; flex:1; display:flex; flex-direction:column; }
  .rel-meta{
    display:flex; align-items:center; gap:8px; margin-bottom:8px;
  }
  .rel-cat{
    font-size:10px; font-weight:700; letter-spacing:.1em;
    text-transform:uppercase; color:var(--accent);
  }
  .rel-dot{ width:2px; height:2px; border-radius:50%; background:#c0bac8; flex-shrink:0; }
  .rel-read{ font-size:11px; font-weight:600; color:var(--muted); }
  .rel-title{ font-size:15px; font-weight:700; line-height:1.35; color:var(--ink); flex:1; }
  .rel-arrow{ font-size:13px; font-weight:600; color:var(--accent); margin-top:12px; }

  /* ── FOOTER ── */
  .art-footer{
    background:var(--dark); color:#fff;
    padding:22px 32px;
    display:flex; justify-content:space-between;
    align-items:center; flex-wrap:wrap; gap:12px;
  }
  .art-footer-brand{ display:flex; align-items:center; gap:9px; font-weight:800; font-size:15px; }
  .art-footer-logo{
    width:28px; height:28px; border-radius:6px;
    object-fit:contain; background:#fff; padding:2px;
  }
  .art-footer-copy{ font-size:12px; color:#857fa0; }
  .art-footer-links{ display:flex; gap:16px; font-size:13px; }
  .art-footer-links a{ color:#a59fc0; transition:color .12s; }
  .art-footer-links a:hover{ color:#fff; }

  /* ── RESPONSIVE ── */
  @media(max-width:860px){
    .art-layout{ grid-template-columns:1fr; gap:0; }
    .sidebar{ display:none; }
  }
  @media(max-width:600px){
    .art-hero-inner{ padding:0 18px 28px; }
    .art-layout{ padding:28px 18px 64px; }
    .related-wrap{ padding:0 18px; }
    .art-footer{ padding:18px; flex-direction:column; align-items:flex-start; }
    .art-hero-img{ max-height:200px; }
    .art-author{ flex-direction:column; }
    .art-share{ gap:8px; }
  }
</style>

<!-- Prose styles are global because <Content /> renders markdown HTML that does not
     carry Astro's scope hash — scoped rules would never match those elements. -->
<style is:global>
  .prose > p:first-child{
    font-size:16px; line-height:1.72; color:#2a2545;
    margin-bottom:28px; font-weight:500;
    letter-spacing:0; word-spacing:0.03em;
    border-left:3px solid var(--accent);
    padding-left:18px;
  }
  .prose h2{
    font-weight:800; font-size:clamp(22px,2.8vw,30px);
    color:var(--ink); margin:60px 0 14px; line-height:1.15;
    letter-spacing:-.022em;
  }
  .prose h3{
    font-weight:700; font-size:clamp(18px,2.2vw,22px);
    color:#2a2545; margin:38px 0 8px; line-height:1.28;
    letter-spacing:-.012em;
  }
  .prose p{
    font-size:14px; line-height:1.75;
    letter-spacing:0.012em; word-spacing:0.05em;
    color:#3b3657; margin-bottom:28px;
  }
  .prose ul, .prose ol{ padding-left:26px; margin-bottom:24px; }
  .prose p:has(+ ul),
  .prose p:has(+ ol){ margin-bottom:8px; }
  .prose li{
    font-size:14px; line-height:1.65;
    letter-spacing:0.012em; word-spacing:0.05em;
    color:#3b3657; margin-bottom:10px;
  }
  .prose li::marker{ color:var(--accent); font-weight:700; }
  .prose strong{ font-weight:700; color:#1e1a35; }
  .prose em{ font-style:italic; }
  .prose hr{ border:none; border-top:1px solid #ede8f8; margin:52px 0; }
  .prose blockquote{
    background:#efeafc; border-radius:14px;
    padding:22px 26px; margin:36px 0;
    font-style:italic; line-height:1.78; color:#2a2545; border:none;
  }
  .prose blockquote p{ font-size:14px; margin-bottom:10px; color:#2a2545; }
  .prose blockquote p:last-child{ margin-bottom:0; }
  .prose blockquote > p:first-child > strong:first-child{
    display:block; font-style:normal; font-weight:700;
    color:var(--ink); margin-bottom:12px; letter-spacing:.01em;
    text-transform:uppercase; font-size:12px; opacity:.7;
  }
  .prose blockquote ul, .prose blockquote ol{ margin-bottom:0; }
  .prose blockquote li{ font-size:14px; color:#3b3657; margin-bottom:8px; }
  .prose code{
    background:#f0ebfa; color:var(--accent);
    padding:2px 7px; border-radius:5px; font-size:13px;
  }
  .prose pre{
    background:var(--dark); border-radius:12px;
    padding:22px 24px; overflow-x:auto; margin:28px 0;
  }
  .prose pre code{ background:none; color:#e2dbf6; padding:0; font-size:13px; }
  .prose table{
    width:100%; border-collapse:collapse;
    margin:36px 0; font-size:14px;
    border-radius:12px; overflow:hidden;
    border:1px solid #ede8f8;
    box-shadow:0 2px 12px -8px rgba(33,29,51,.12);
  }
  .prose thead th{
    background:#efeafc; color:var(--ink); font-weight:700;
    padding:13px 16px; text-align:left; font-size:13px;
    letter-spacing:.03em; text-transform:uppercase;
    border-bottom:2px solid #ddd6f5;
  }
  .prose tbody td{
    padding:12px 16px; color:#3b3657; font-size:14px;
    border-bottom:1px solid #f2eefb; vertical-align:top; line-height:1.6;
  }
  .prose tbody tr:last-child td{ border-bottom:none; }
  .prose tbody tr:hover td{ background:#faf7ff; }
  .prose a{ color:var(--accent); text-decoration:underline; text-underline-offset:3px; }
  .prose a:hover{ opacity:.8; }

  /* Inline CTA banner — JS-injected, needs global scope */
  .mid-cta{
    display:flex; align-items:center; justify-content:space-between; gap:24px;
    background:#efeafc;
    border-left:4px solid #7c5cd6;
    border-radius:0 12px 12px 0;
    padding:20px 24px; margin:44px 0;
    flex-wrap:wrap;
  }
  .mid-cta-text{ flex:1; min-width:180px; }
  .mid-cta-label{
    font-size:10px; font-weight:700; letter-spacing:.14em;
    text-transform:uppercase; color:#7c5cd6; margin-bottom:6px;
  }
  .mid-cta-heading{
    font-size:15px; font-weight:800; color:#211d33;
    line-height:1.3; margin-bottom:6px;
  }
  .mid-cta-body{
    font-size:13px; color:#4a4560; line-height:1.6;
  }
  .mid-cta a.mid-cta-btn{
    display:inline-block; white-space:nowrap; flex-shrink:0;
    background:#7c5cd6; color:#fff;
    font-size:13px; font-weight:700;
    padding:10px 20px; border-radius:999px;
    text-decoration:none;
    transition:background .15s, transform .15s;
  }
  .mid-cta a.mid-cta-btn:hover{ background:#6347c0; color:#fff; transform:translateY(-1px); }
</style>

<!-- Article hero -->
<div class="art-hero">
  <div class="art-hero-inner">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">›</span>
      <a href="/articles/">Articles</a>
      <span class="breadcrumb-sep">›</span>
      <span>{article.data.category}</span>
    </nav>
    <span class="tag">{article.data.category}</span>
    <h1>{article.data.title}</h1>
    <div class="art-meta">
      <span class="art-meta-dateline">
        <span class="art-meta-datelabel">Published</span>
        <time datetime={article.data.date}>{formattedDate}</time>
      </span>
      {formattedLastModified && (
        <>
          <span class="art-meta-dot"></span>
          <span class="art-meta-dateline">
            <span class="art-meta-datelabel">Updated</span>
            <time datetime={article.data.lastModified}>{formattedLastModified}</time>
          </span>
        </>
      )}
      <span class="art-meta-dot"></span>
      <span>{article.data.readTime}</span>
      <span class="art-meta-dot"></span>
      <span class="art-meta-author">Written by C. Sivaraj</span>
    </div>
    <!-- Hero image below meta — NP layout -->
    <img src={article.data.image} alt={article.data.title} class="art-hero-img" loading="eager" />
  </div>
</div>

<!-- Article body + sidebar -->
<div class="art-layout">
  <!-- Prose -->
  <div>
    <!-- Key Takeaways — NP's "first section" pattern -->
    {article.data.keyTakeaways && article.data.keyTakeaways.length > 0 && (
      <div class="key-takeaways">
        <div class="kt-label">Key Takeaways</div>
        <ul>
          {article.data.keyTakeaways.map(point => (
            <li>{point}</li>
          ))}
        </ul>
      </div>
    )}

    <article class="prose">
      <Content />
    </article>

    <!-- Share row -->
    <div class="art-share">
      <span class="art-share-label">Share:</span>
      <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${Astro.url}`} target="_blank" class="share-btn">
        <svg viewBox="0 0 24 24" width="13" fill="currentColor"><path d="M4.98 3.5A2.5 2.5 0 002.5 6a2.5 2.5 0 105 0 2.5 2.5 0 00-2.52-2.5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.76V21H18.6v-5.3c0-1.26-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21H11z"/></svg>
        LinkedIn
      </a>
      <a href={`https://twitter.com/intent/tweet?url=${Astro.url}&text=${encodeURIComponent(article.data.title)}`} target="_blank" class="share-btn">
        <svg viewBox="0 0 24 24" width="13" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        X / Twitter
      </a>

      <span class="share-sep">|</span>
      <span class="art-share-label">Ask AI:</span>

      <a href={`https://chatgpt.com/?q=${encodeURIComponent('Summarize the key insights from this article: ' + Astro.url.toString())}`} target="_blank" class="share-btn share-btn--chatgpt">
        <svg viewBox="0 0 24 24" width="13" fill="currentColor"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0L4.01 14.25a4.5 4.5 0 0 1-1.67-6.354zm16.597 3.855l-5.843-3.369 2.02-1.168a.076.076 0 0 1 .071 0l4.808 2.773a4.5 4.5 0 0 1-.698 8.115v-5.678a.79.79 0 0 0-.358-.673zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.808-2.773a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/></svg>
        ChatGPT
      </a>
