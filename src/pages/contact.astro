<style>
  .contact-main{
    min-height: calc(100vh - 72px - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    background: #faf9fd;
  }
  .contact-wrap{
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .contact-eyebrow{
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .contact-heading{
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    color: var(--ink);
    line-height: 1.12;
    letter-spacing: -.03em;
    margin-bottom: 18px;
  }
  .contact-sub{
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 44px;
  }

  .email-card{
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: #fff;
    border: 1.5px solid #e4ddf7;
    border-radius: 16px;
    padding: 20px 28px;
    text-decoration: none;
    transition: border-color .15s, box-shadow .15s, transform .15s;
    box-shadow: 0 2px 16px rgba(124,92,214,.06);
    width: 100%;
    max-width: 420px;
    justify-content: space-between;
  }
  .email-card:hover{
    border-color: var(--accent);
    box-shadow: 0 6px 28px rgba(124,92,214,.14);
    transform: translateY(-2px);
  }
  .email-icon{
    color: var(--accent);
    flex-shrink: 0;
    display: flex;
  }
  .email-address{
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -.01em;
    flex: 1;
    text-align: left;
  }
  .email-arrow{
    font-size: 18px;
    color: var(--accent);
    flex-shrink: 0;
    line-height: 1;
  }

  .contact-divider{
    width: 40px;
    height: 2px;
    background: #e4ddf7;
    border-radius: 2px;
    margin: 44px auto 20px;
  }
  .contact-also{
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #b0a9c8;
    margin-bottom: 16px;
  }

  .social-row{
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
  }
  .social-pill{
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    background: #f0ebfa;
    color: var(--accent);
    text-decoration: none;
    transition: background .14s, color .14s;
  }
  .social-pill:hover{ background: var(--accent); color: #fff; }
  .social-pill--wa{ background: #e6f9ef; color: #1a9f4f; }
  .social-pill--wa:hover{ background: #25D366; color: #fff; }

  @media(max-width: 480px){
    .contact-main{ padding: 60px 16px; }
    .email-card{ padding: 18px 20px; }
    .email-address{ font-size: 13px; }
  }
</style>
