---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'C. Sivaraj – SEO Analyst & AEO / GEO Specialist';
const description =
  'SEO & AI-search analyst helping brands earn visibility across Google AI Overviews, ChatGPT, Gemini, Perplexity, Bing AI and Copilot — backed by 5+ years of enterprise SEO.';
const keywords =
  'SEO analyst, AEO, GEO, AI search optimization, enterprise SEO, Google AI Overviews, generative engine optimization, C. Sivaraj';
---

<BaseLayout {title} {description} {keywords} author="C. Sivaraj">

<style>
  *{ box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  h1,h2,h3{ margin:0; letter-spacing:-.02em; line-height:1.08; }
  p{ margin:0; }
  a{ color:inherit; text-decoration:none; }
  ::selection{ background:var(--accent); color:#fff; }

  .wrap{ max-width:1120px; margin:0 auto; padding:0 32px; }
  .em{ color:var(--accent); }
  .ulink{ background:linear-gradient(var(--accent),var(--accent)) 0 92%/100% 2px no-repeat; }

  .pill{
    display:inline-flex; align-items:center; gap:8px;
    border-radius:999px; font-weight:600; font-size:15px;
    padding:14px 26px; transition:transform .18s, box-shadow .18s;
    cursor:pointer;
  }
  .pill:hover{ transform:translateY(-2px); }
  .cta{ background:var(--cta); color:#fff; box-shadow:0 10px 24px -8px rgba(236,109,146,.6); }
  .cta:hover{ box-shadow:0 14px 30px -8px rgba(236,109,146,.7); }
  .ghost{ background:#fff; color:var(--ink); box-shadow:0 6px 20px -10px rgba(33,29,51,.4); }

  .tag{
    display:inline-flex; align-items:center; gap:7px;
    font-size:12px; font-weight:700; letter-spacing:.12em;
    text-transform:uppercase; color:var(--accent);
  }
  .tag::before{ content:''; width:7px; height:7px; border-radius:50%; background:var(--accent); }

  .card{
    background:#fff; border-radius:22px;
    box-shadow:0 18px 50px -28px rgba(33,29,51,.45);
    transition:transform .22s, box-shadow .22s;
  }
  .lift:hover{ transform:translateY(-6px); box-shadow:0 30px 60px -28px rgba(33,29,51,.5); }

  .ico{
    width:54px; height:54px; border-radius:15px;
    display:flex; align-items:center; justify-content:center;
    flex-shrink:0;
  }

  .hsoc{
    display:inline-flex; align-items:center; gap:8px;
    transition:transform .15s, color .15s, box-shadow .15s;
  }
  .hsoc:hover{ color:var(--accent); transform:translateY(-2px); box-shadow:0 8px 18px -8px rgba(33,29,51,.55); }

  .soc{
    display:inline-flex; align-items:center; gap:8px;
    transition:transform .15s, background .15s, color .15s;
  }
  .soc:hover{ background:#2c2450; color:#fff; transform:translateY(-2px); }

  @keyframes float{ 0%,100%{ transform:translateY(0) } 50%{ transform:translateY(-14px) } }
  .floaty{ animation:float 5.5s ease-in-out infinite; }

  .clouds{
    height:38px;
    background:radial-gradient(circle 22px at 22px 38px,#fff 0 22px,transparent 23px) 0 0/44px 38px repeat-x;
  }

  .marquee{ display:flex; gap:54px; white-space:nowrap; animation:scrollx 26s linear infinite; }
  @keyframes scrollx{ from{ transform:translateX(0) } to{ transform:translateX(-50%) } }

  /* ── HERO ── */
  .hero{
    background:linear-gradient(165deg,#efeafc 0%,#f7ecf2 52%,#fde9dc 100%);
    position:relative; overflow:hidden;
  }
  .hero-inner{
    display:grid; grid-template-columns:1.05fr .95fr;
    gap:40px; align-items:center;
    padding-top:72px; padding-bottom:40px;
  }
  .hero-badge{
    background:#fff; padding:8px 14px; border-radius:999px;
    box-shadow:0 6px 18px -10px rgba(33,29,51,.4);
  }
  h1{
    font-weight:800; font-size:clamp(38px,5.2vw,64px);
    margin:22px 0 0; color:var(--ink);
  }
  .hero-desc{
    font-size:18px; line-height:1.65; color:var(--muted);
    margin-top:22px; max-width:48ch;
  }
  .hero-ctas{ display:flex; gap:14px; margin-top:30px; flex-wrap:wrap; }
  .hero-socials{ display:flex; align-items:center; gap:10px; margin-top:30px; flex-wrap:wrap; }

  .hero-photo{ position:relative; display:flex; justify-content:center; }
  .hero-blob{
    position:absolute; width:300px; height:300px; border-radius:50%;
    background:radial-gradient(circle at 30% 30%,#c9b6f4,#a988ec);
    filter:blur(2px); top:8%;
  }
  .hero-img{
    position:relative; width:300px; height:380px;
    border-radius:26px; object-fit:cover; object-position:center top;
    box-shadow:0 30px 60px -24px rgba(86,54,160,.5);
  }
  .stat-card-left{
    position:absolute; left:-8px; bottom:40px;
    padding:14px 16px; border-radius:16px; animation-delay:1.2s;
  }
  .stat-card-right{
    position:absolute; right:-6px; top:30px;
    padding:12px 15px; border-radius:16px;
    display:flex; align-items:center; gap:9px; animation-delay:.5s;
  }
  .stat-green{ font-weight:800; font-size:22px; color:#2fae74; }
  .stat-lbl{ font-size:11px; color:var(--muted); }

  /* ── INTRO ── */
  .intro{ padding:74px 0 10px; text-align:center; }
  .intro-wrap{ max-width:880px; margin:0 auto; }
  .intro h2{ font-weight:700; font-size:clamp(26px,3.4vw,38px); margin-top:18px; }
  .intro p{ font-size:16px; line-height:1.7; color:var(--muted); margin-top:20px; max-width:62ch; margin-left:auto; margin-right:auto; }

  /* ── FEATURES ── */
  .features{ padding:48px 0 64px; }
  .features-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:26px; }
  .feat-ico{ width:54px; height:54px; border-radius:15px; display:flex; align-items:center; justify-content:center; }
  .feat h3{ font-size:17px; font-weight:700; margin-top:16px; }
  .feat p{ font-size:14px; line-height:1.6; color:var(--muted); margin-top:7px; }

  /* ── STAT BAR ── */
  .stat-bar{ padding-bottom:78px; }
  .stat-bar-card{
    display:grid; grid-template-columns:repeat(4,1fr);
    gap:20px; padding:34px 40px; border-radius:24px;
    background:linear-gradient(120deg,#fff,#faf6ff);
  }
  .stat-item{ text-align:center; }
  .stat-item+.stat-item{ border-left:1px solid #ece7f6; }
  .stat-num{ font-weight:800; font-size:36px; }
  .stat-sub{ font-size:13px; color:var(--muted); margin-top:4px; }

  /* ── SERVICES ── */
  .services-sec{
    background:linear-gradient(180deg,#fdeee5 0%,#f6ecf6 100%);
    padding:74px 0 88px;
  }
  .sec-head{ text-align:center; max-width:680px; margin:0 auto 46px; }
  .sec-head h2{ font-weight:800; font-size:clamp(30px,4vw,46px); margin-top:16px; }
  .sec-head p{ font-size:16px; line-height:1.7; color:var(--muted); margin-top:16px; }
  .services-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
  .svc-card{ padding:30px 28px; }
  .svc-card h3{ font-size:19px; font-weight:700; margin-top:18px; }
  .svc-card p{ font-size:14px; line-height:1.65; color:var(--muted); margin-top:9px; }

  /* ── ABOUT ── */
  .about-sec{
    padding:84px 0;
    display:grid; grid-template-columns:.95fr 1.05fr;
    gap:56px; align-items:center;
  }
  .about-photo{ position:relative; }
  .about-deco{
    position:absolute; inset:auto auto -16px -16px;
    width:130px; height:130px; border-radius:24px;
    background:#fde7da; z-index:0;
  }
  .about-img{
    position:relative; z-index:1; width:100%;
    aspect-ratio:4/3.4; object-fit:cover; object-position:center top;
    border-radius:22px; display:block;
  }
  .about-badge{
    position:absolute; z-index:2; right:-14px; bottom:-18px;
    padding:16px 18px; border-radius:18px;
    display:flex; align-items:center; gap:11px;
  }
  .about-years{
    width:42px; height:42px; border-radius:12px;
    background:#e3f3ea; color:#2fae74;
    font-weight:800; font-size:16px;
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .about-text h2{ font-weight:800; font-size:clamp(28px,3.6vw,42px); margin-top:16px; }
  .about-text > p{ font-size:16px; line-height:1.7; color:var(--muted); margin-top:16px; }
  .about-pillars{
    display:grid; grid-template-columns:1fr 1fr;
    gap:18px 26px; margin-top:28px;
  }
  .pillar{ display:flex; gap:11px; align-items:flex-start; }
  .pillar-check{
    width:26px; height:26px; border-radius:8px;
    background:#efe9fc; color:var(--accent);
    display:flex; align-items:center; justify-content:center; flex-shrink:0;
  }
  .pillar strong{ display:block; font-weight:700; font-size:15px; }
  .pillar span{ font-size:13px; color:var(--muted); }

  /* ── RESULTS ── */
  .results-sec{ background:var(--dark); color:#fff; padding:82px 0; }
  .results-head{
    display:flex; align-items:flex-end; justify-content:space-between;
    flex-wrap:wrap; gap:18px; margin-bottom:42px;
  }
  .results-head .tag{ color:#c3b1f5; }
  .results-head .tag::before{ background:#c3b1f5; }
  .results-head h2{ font-weight:800; font-size:clamp(30px,4vw,46px); margin-top:14px; color:#fff; }
  .results-head p{ font-size:15px; color:#a59fc0; max-width:34ch; }
  .results-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
  .res-card{
    background:#1f1a38; border-radius:22px;
    overflow:hidden; padding:30px 28px;
    transition:transform .22s, box-shadow .22s;
  }
  .res-card:hover{ transform:translateY(-6px); box-shadow:0 30px 60px -28px rgba(33,29,51,.5); }
  .res-cat{ font-size:12px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#c3b1f5; }
  .res-num{ font-weight:800; font-size:40px; color:#7bd0a4; display:block; margin-top:16px; }
  .res-card h3{ font-size:18px; font-weight:700; margin-top:8px; color:#fff; }
  .res-card p{ font-size:14px; color:#a59fc0; margin-top:10px; line-height:1.6; }
  .res-row{
    margin-top:24px; background:#1f1a38; border-radius:22px;
    padding:26px 30px; display:flex; align-items:center; gap:18px; flex-wrap:wrap;
  }
  .res-row-ico{ background:rgba(124,92,214,.25); color:#c3b1f5; flex-shrink:0; }
  .res-row h3{ font-size:17px; font-weight:700; color:#fff; }
  .res-row p{ font-size:14px; color:#a59fc0; margin-top:5px; line-height:1.55; }

  /* ── ARTICLES ── */
  .articles-sec{
    background:linear-gradient(180deg,#f6ecf6 0%,#fdeee5 100%);
    padding:78px 0 88px;
  }
  .articles-head{
    display:flex; align-items:flex-end; justify-content:space-between;
    flex-wrap:wrap; gap:18px; margin-bottom:44px;
  }
  .articles-head h2{ font-weight:800; font-size:clamp(30px,4vw,46px); margin-top:14px; }
  .articles-head p{ font-size:16px; line-height:1.7; color:var(--muted); margin-top:14px; }
  .articles-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
  .art-card{
    display:flex; flex-direction:column; overflow:hidden;
    background:#fff; border-radius:22px;
    box-shadow:0 18px 50px -28px rgba(33,29,51,.45);
    transition:transform .22s, box-shadow .22s;
  }
  .art-card:hover{ transform:translateY(-6px); box-shadow:0 30px 60px -28px rgba(33,29,51,.5); }
  .art-card img{ width:100%; height:190px; object-fit:cover; display:block; }
  .art-body{ padding:24px 26px 26px; display:flex; flex-direction:column; flex:1; }
  .art-tag{ color:var(--cta); }
  .art-tag::before{ background:var(--cta); }
  .art-body h3{ font-size:19px; font-weight:700; margin-top:12px; line-height:1.25; }
  .art-body p{ font-size:14px; line-height:1.6; color:var(--muted); margin-top:10px; flex:1; }
  .art-link{ font-size:14px; font-weight:600; margin-top:16px; align-self:flex-start; }

  /* ── CREDENTIALS ── */
  .creds-sec{
    background:linear-gradient(180deg,#f7f2ff,#fdeef0);
    padding:84px 0;
  }
  .creds-inner{ display:flex; flex-direction:column; gap:54px; }
  .creds-2col{ display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-top:28px; }
  .edu-card{ padding:22px 24px; }
  .edu-head{ display:flex; justify-content:space-between; gap:10px; flex-wrap:wrap; }
  .edu-degree{ font-weight:700; font-size:17px; }
  .edu-years{ font-size:13px; color:var(--accent); font-weight:600; white-space:nowrap; }
  .edu-school{ font-size:14px; color:var(--muted); margin-top:4px; }
  .exp-card{ padding:22px 24px; }
  .exp-head{ display:flex; justify-content:space-between; gap:12px; flex-wrap:wrap; }
  .exp-title{ font-size:18px; font-weight:700; margin:0; }
  .exp-period{ font-size:13px; color:var(--accent); font-weight:600; white-space:nowrap; }
  .exp-company{ font-size:14px; color:var(--muted); margin-top:3px; }
  .exp-desc{ font-size:13px; color:#615c75; margin-top:10px; line-height:1.6; }
  .cert-card{
    padding:20px 22px; display:flex; gap:13px; align-items:flex-start;
    border-radius:22px; box-shadow:0 18px 50px -28px rgba(33,29,51,.45);
    background:#fff; transition:transform .22s, box-shadow .22s;
  }
  .cert-card:hover{ transform:translateY(-6px); box-shadow:0 30px 60px -28px rgba(33,29,51,.5); }
  .cert-ico{ width:40px; height:40px; border-radius:11px; flex-shrink:0; display:flex; align-items:center; justify-content:center; }
  .cert-name{ font-weight:700; font-size:15px; display:block; }
  .cert-issuer{ font-size:13px; color:var(--muted); display:block; margin-top:2px; }
  .cert-verify{ font-size:12px; font-weight:600; color:var(--accent); display:inline-flex; align-items:center; gap:4px; margin-top:8px; }

  /* ── TOOLS MARQUEE ── */
  .tools-sec{
    padding:54px 0; overflow:hidden;
    border-top:1px solid #f0e9f6; border-bottom:1px solid #f0e9f6;
  }
  .tools-label{ text-align:center; margin-bottom:28px; }
  .marquee-track{ overflow:hidden; }
  .marquee-inner{ display:flex; gap:54px; white-space:nowrap; animation:scrollx 26s linear infinite; font-weight:700; font-size:22px; color:#b3a8c8; }

  /* ── CONTACT ── */
  .contact-sec{ background:var(--dark); color:#fff; padding:56px 0 0; }
  .contact-tag{ color:#c3b1f5; }
  .contact-tag::before{ background:#c3b1f5; }
  .contact-h2{ font-weight:800; font-size:clamp(30px,4.2vw,48px); margin-top:16px; color:#fff; }
  .contact-desc{ font-size:16px; color:#a59fc0; margin-top:16px; max-width:44ch; line-height:1.7; }
  .contact-links{ display:flex; flex-wrap:wrap; gap:14px 40px; margin-top:28px; }
  .contact-item{ display:flex; align-items:center; gap:14px; }
  .contact-ico{ display:flex; align-items:center; justify-content:center; width:54px; height:54px; border-radius:15px; flex-shrink:0; }
  .contact-lbl{ font-size:12px; color:#857fa0; }
  .contact-val{ font-weight:600; }
  .follow-label{ font-size:12px; color:#857fa0; margin-bottom:8px; }
  .follow-icons{ display:flex; gap:10px; }
  .soc-btn{
    width:44px; height:44px; border-radius:12px;
    background:#211a3e; border:1px solid #322a52;
    color:#c3b1f5; display:inline-flex; align-items:center; justify-content:center;
    transition:background .15s, color .15s, transform .15s;
  }
  .soc-btn:hover{ background:#2c2450; color:#fff; transform:translateY(-2px); }
  .contact-footer{
    margin-top:44px; border-top:1px solid #2a2348;
    padding:26px 32px; display:flex;
    justify-content:space-between; align-items:center;
    flex-wrap:wrap; gap:14px;
  }
  .cf-brand{ display:flex; align-items:center; gap:10px; font-weight:800; }
  .cf-logo{ width:28px; height:28px; border-radius:6px; object-fit:contain; background:#fff; padding:2px; }
  .cf-copy{ font-size:13px; color:#857fa0; }
  .cf-links{ display:flex; gap:18px; font-size:13px; color:#a59fc0; flex-wrap:wrap; }
  .cf-links a{ color:#a59fc0; }
  .cf-links a:hover{ color:#fff; }

  /* ── RESPONSIVE ── */
  @media(max-width:900px){
    .hero-inner{ grid-template-columns:1fr; }
    .hero-photo{ display:none; }
    .features-grid{ grid-template-columns:repeat(2,1fr); }
    .stat-bar-card{ grid-template-columns:repeat(2,1fr); }
    .stat-item+.stat-item{ border-left:none; }
    .stat-item:nth-child(odd){ border-right:none; }
    .services-grid{ grid-template-columns:repeat(2,1fr); }
    .about-sec{ grid-template-columns:1fr; }
    .about-photo{ display:none; }
    .results-grid{ grid-template-columns:1fr; }
    .articles-grid{ grid-template-columns:1fr; }
    .creds-2col{ grid-template-columns:1fr; }
    .about-pillars{ grid-template-columns:1fr; }
  }
  @media(max-width:600px){
    .wrap{ padding:0 16px; }
    .services-grid{ grid-template-columns:1fr; }
    .features-grid{ grid-template-columns:1fr 1fr; }
    .articles-head{ flex-direction:column; align-items:flex-start; }
    .results-head{ flex-direction:column; }
    .stat-bar-card{ padding:24px 20px; }
    .hero-desc{ font-size:16px; }
    .pill{ font-size:14px; padding:12px 20px; }
    .hero-ctas{ gap:10px; }
  }
</style>

<!-- ── HERO ── -->
<section id="top" class="hero">
  <div class="wrap">
    <div class="hero-inner">
      <div>
        <span class="tag hero-badge">SEO Analyst · AEO / GEO · 5+ years</span>
        <h1>Get found in Google, and in <span class="em">every AI answer engine.</span></h1>
